---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Benchmark — GitHacker" description="Automated comparison of .git folder exploitation tools.">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="section">
      <h1 class="text-3xl font-bold mb-2">Benchmark</h1>
      <p class="text-gray-600">
        Automated comparison of <code>.git</code> folder exploitation tools across multiple web server configurations.
      </p>
      <div id="metadata" class="mt-2 text-xs text-gray-400"></div>
    </div>

    <!-- Loading -->
    <div id="loading" class="py-16 text-center text-sm text-gray-400">
      Loading benchmark data...
    </div>

    <!-- Error -->
    <div id="error" class="hidden py-16 text-center text-sm text-red-600">
      Failed to load benchmark data. Ensure <code>data/benchmark.json</code> is available.
    </div>

    <!-- Content -->
    <div id="content" class="hidden">

      <!-- Tool Versions -->
      <div class="section">
        <h2 class="text-xl font-semibold mb-4">Tools Under Test</h2>
        <div id="tool-versions" class="overflow-x-auto"></div>
      </div>

      <!-- Feature Comparison -->
      <div class="section">
        <h2 class="text-xl font-semibold mb-4">Feature Comparison</h2>
        <div class="flex gap-2 mb-4 flex-wrap">
          <button data-group="index-enabled" class="group-tab text-xs px-3 py-1.5 rounded border border-gray-900 bg-gray-900 text-white">DirectoryIndex Enabled</button>
          <button data-group="index-disabled" class="group-tab text-xs px-3 py-1.5 rounded border border-gray-300 text-gray-600 hover:border-gray-400">DirectoryIndex Disabled</button>
          <button data-group="all" class="group-tab text-xs px-3 py-1.5 rounded border border-gray-300 text-gray-600 hover:border-gray-400">All Scenarios</button>
        </div>
        <div id="feature-matrix" class="overflow-x-auto"></div>
      </div>

      <!-- Detailed Results -->
      <div class="section">
        <h2 class="text-xl font-semibold mb-4">Detailed Results</h2>
        <div class="mb-4 flex items-center gap-2">
          <label for="scenario-select" class="text-xs text-gray-500">Scenario:</label>
          <select id="scenario-select" class="text-xs border border-gray-300 rounded px-2 py-1.5 bg-white"></select>
        </div>
        <div id="detail-table" class="overflow-x-auto"></div>
      </div>

      <!-- Overall Scores -->
      <div class="section">
        <h2 class="text-xl font-semibold mb-4">Overall Recovery Rate</h2>
        <p class="text-sm text-gray-500 mb-4">Average file recovery rate across all test scenarios.</p>
        <div id="score-cards" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
      </div>

    </div>
  </div>

  <script>
    let data: any = null;
    let currentGroup = 'index-enabled';
    let currentScenario: string | null = null;

    const FEAT: Record<string, string> = {
      source_code: 'Source Code', reflogs: 'Reflogs', stashes: 'Stashes',
      commits: 'Commits', branches: 'Branches', remotes: 'Remotes', tags: 'Tags',
    };

    const SCEN: Record<string, string> = {
      'apache-index-enabled': 'Apache (Index On)', 'apache-index-disabled': 'Apache (Index Off)',
      'nginx-index-enabled': 'Nginx (Index On)', 'nginx-index-disabled': 'Nginx (Index Off)',
      'php-lfi': 'PHP LFI',
    };

    const GROUPS: Record<string, string[] | null> = {
      'index-enabled': ['apache-index-enabled', 'nginx-index-enabled'],
      'index-disabled': ['apache-index-disabled', 'nginx-index-disabled'],
      'all': null,
    };

    document.addEventListener('DOMContentLoaded', async () => {
      try {
        const res = await fetch('/data/benchmark.json');
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        data = await res.json();
        init();
      } catch {
        document.getElementById('loading')!.classList.add('hidden');
        document.getElementById('error')!.classList.remove('hidden');
      }
    });

    function init() {
      document.getElementById('loading')!.classList.add('hidden');
      document.getElementById('content')!.classList.remove('hidden');

      const m = data.metadata;
      const date = new Date(m.generated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
      document.getElementById('metadata')!.textContent =
        `Generated ${date} · commit ${m.git_commit} · seed ${m.test_repo_seed}`;

      document.querySelectorAll('.group-tab').forEach(btn => {
        btn.addEventListener('click', () => {
          currentGroup = (btn as HTMLElement).dataset.group!;
          document.querySelectorAll('.group-tab').forEach(b => {
            const active = b === btn;
            (b as HTMLElement).className = `group-tab text-xs px-3 py-1.5 rounded border ${active ? 'border-gray-900 bg-gray-900 text-white' : 'border-gray-300 text-gray-600 hover:border-gray-400'}`;
          });
          renderMatrix();
        });
      });

      const sel = document.getElementById('scenario-select') as HTMLSelectElement;
      data.scenarios.forEach((s: string) => {
        const o = document.createElement('option');
        o.value = s;
        o.textContent = SCEN[s] || s;
        sel.appendChild(o);
      });
      currentScenario = data.scenarios[0];
      sel.addEventListener('change', () => { currentScenario = sel.value; renderDetail(); });

      renderVersions();
      renderMatrix();
      renderDetail();
      renderScores();
    }

    function toolOrder(): string[] {
      return Object.keys(data.tools).sort((a, b) =>
        a === 'githacker' ? -1 : b === 'githacker' ? 1 : a.localeCompare(b));
    }

    function activeScenarios(): string[] {
      return GROUPS[currentGroup] ?? data.scenarios;
    }

    function esc(s: string) {
      const d = document.createElement('div');
      d.textContent = s;
      return d.innerHTML;
    }

    // -- Tool Versions Table --
    function renderVersions() {
      const tools = toolOrder();
      let h = '<table class="data-table"><thead><tr><th>Tool</th><th>Version / Commit</th><th>Repository</th></tr></thead><tbody>';
      for (const tid of tools) {
        const t = data.tools[tid];
        const hl = tid === 'githacker';
        const ver = t.version || 'unknown';
        h += `<tr class="${hl ? 'row-highlight' : ''}">`;
        h += `<td>${esc(t.name)}</td>`;
        h += `<td><code class="text-xs">${esc(ver)}</code></td>`;
        h += `<td><a href="${esc(t.url)}" target="_blank" rel="noopener" class="underline text-xs hover:text-gray-900">${esc(t.url.replace('https://github.com/', ''))}</a></td>`;
        h += '</tr>';
      }
      h += '</tbody></table>';
      document.getElementById('tool-versions')!.innerHTML = h;
    }

    // -- Feature Comparison Matrix --
    function renderMatrix() {
      const sc = activeScenarios();
      const tools = toolOrder();
      let h = '<table class="data-table"><thead><tr><th>Tool</th>';
      for (const f of data.features) h += `<th>${FEAT[f] || f}</th>`;
      h += '</tr></thead><tbody>';

      for (const tid of tools) {
        const t = data.tools[tid];
        const hl = tid === 'githacker';
        h += `<tr class="${hl ? 'row-highlight' : ''}"><td>${esc(t.name)}</td>`;
        for (const f of data.features) {
          let sup = false, tc = 0, tf = 0;
          for (const s of sc) {
            const r = data.results[tid]?.[s]?.features?.[f];
            if (r) { if (r.supported) sup = true; tc += r.correct; tf += r.total; }
          }
          const ratio = tf > 0 ? tc / tf * 100 : 0;
          let icon: string;
          if (sup && ratio === 100) icon = '<span class="text-gray-900 font-medium">&#10003;</span>';
          else if (sup && ratio > 0) icon = `<span class="text-gray-500">${ratio.toFixed(0)}%</span>`;
          else icon = '<span class="text-gray-300">&times;</span>';
          h += `<td>${icon}</td>`;
        }
        h += '</tr>';
      }
      h += '</tbody></table>';
      document.getElementById('feature-matrix')!.innerHTML = h;
    }

    // -- Detailed Results Table --
    function renderDetail() {
      const sc = currentScenario!;
      const tools = toolOrder();
      let h = '<table class="data-table"><thead><tr>';
      h += '<th>Tool</th><th>Recovery Rate</th><th>Duration</th><th>HTTP Reqs</th><th>Exit</th><th></th>';
      h += '</tr></thead><tbody>';

      for (const tid of tools) {
        const t = data.tools[tid];
        const r = data.results[tid]?.[sc];
        const hl = tid === 'githacker';
        if (!r) {
          h += `<tr class="${hl ? 'row-highlight' : ''}"><td>${esc(t.name)}</td><td colspan="5" class="text-gray-300 text-xs">No data</td></tr>`;
          continue;
        }

        const rc = r.ratio >= 90 ? 'high' : r.ratio >= 50 ? 'mid' : 'low';
        const dur = r.duration != null ? `${r.duration.toFixed(1)}s` : '—';
        const reqs = r.http_requests != null ? r.http_requests.toLocaleString() : '—';
        const exit = r.exit_code != null ? (r.exit_code === 0 ? '0' : `${r.exit_code}`) : '—';
        const exitCls = r.exit_code === 0 ? 'text-gray-500' : 'text-red-500';
        const hasDetail = r.features || r.absent_files?.length || r.different_files?.length;

        h += `<tr class="${hl ? 'row-highlight' : ''}">`;
        h += `<td>${esc(t.name)}</td>`;
        h += `<td><div class="flex items-center gap-2"><span class="w-14 text-right text-xs">${r.ratio.toFixed(1)}%</span><div class="ratio-bar flex-1"><div class="ratio-fill ${rc}" style="width:${r.ratio}%"></div></div></div></td>`;
        h += `<td class="text-xs text-gray-500">${dur}</td>`;
        h += `<td class="text-xs text-gray-500">${reqs}</td>`;
        h += `<td class="text-xs ${exitCls}">${exit}</td>`;
        h += `<td>${hasDetail ? `<span class="toggle-btn" data-tool="${tid}">details</span>` : ''}</td>`;
        h += '</tr>';

        if (hasDetail) {
          h += `<tr class="detail-row" id="det-${tid}"><td colspan="6">`;
          h += detailContent(r);
          h += '</td></tr>';
        }
      }
      h += '</tbody></table>';
      document.getElementById('detail-table')!.innerHTML = h;

      document.querySelectorAll('.toggle-btn').forEach(el => {
        el.addEventListener('click', () => {
          const tid = (el as HTMLElement).dataset.tool!;
          const row = document.getElementById(`det-${tid}`);
          if (row) {
            row.classList.toggle('open');
            el.textContent = row.classList.contains('open') ? 'hide' : 'details';
          }
        });
      });
    }

    function detailContent(r: any): string {
      let h = '<div class="grid grid-cols-1 md:grid-cols-2 gap-4">';

      if (r.features) {
        h += '<div><p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Per-feature breakdown</p><table class="w-full text-xs">';
        for (const f of data.features) {
          const ft = r.features[f];
          if (!ft) continue;
          const rc = ft.ratio >= 90 ? 'high' : ft.ratio >= 50 ? 'mid' : 'low';
          h += `<tr class="border-b border-gray-100"><td class="py-1 text-gray-600">${FEAT[f]}</td><td class="py-1 text-right text-gray-500">${ft.correct}/${ft.total}</td><td class="py-1 w-20"><div class="ratio-bar"><div class="ratio-fill ${rc}" style="width:${ft.ratio}%"></div></div></td><td class="py-1 text-right w-12">${ft.ratio.toFixed(1)}%</td></tr>`;
        }
        h += '</table></div>';
      }

      h += '<div>';
      if (r.absent_files?.length) {
        h += `<p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Absent files (${r.absent_files.length})</p><ul class="file-list">`;
        for (const f of r.absent_files.slice(0, 30)) h += `<li>${esc(f)}</li>`;
        if (r.absent_files.length > 30) h += `<li class="text-gray-300">... ${r.absent_files.length - 30} more</li>`;
        h += '</ul>';
      }
      if (r.different_files?.length) {
        h += `<p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2 mt-3">Different files (${r.different_files.length})</p><ul class="file-list">`;
        for (const f of r.different_files.slice(0, 30)) h += `<li>${esc(f)}</li>`;
        if (r.different_files.length > 30) h += `<li class="text-gray-300">... ${r.different_files.length - 30} more</li>`;
        h += '</ul>';
      }
      if (!r.absent_files?.length && !r.different_files?.length) {
        h += '<p class="text-xs text-gray-500">All files recovered correctly.</p>';
      }
      h += '</div></div>';
      return h;
    }

    // -- Overall Score Cards --
    function renderScores() {
      const tools = toolOrder();
      const scores: Record<string, {ratio: number, duration: number, requests: number}> = {};
      for (const tid of tools) {
        let sumR = 0, sumD = 0, sumQ = 0, n = 0;
        for (const s of data.scenarios) {
          const r = data.results[tid]?.[s];
          if (r) {
            sumR += r.ratio;
            sumD += (r.duration || 0);
            sumQ += (r.http_requests || 0);
            n++;
          }
        }
        scores[tid] = {
          ratio: n > 0 ? sumR / n : 0,
          duration: n > 0 ? sumD / n : 0,
          requests: n > 0 ? Math.round(sumQ / n) : 0,
        };
      }
      const best = Math.max(...Object.values(scores).map(s => s.ratio));

      let h = '';
      for (const tid of tools) {
        const t = data.tools[tid];
        const sc = scores[tid];
        const isBest = sc.ratio === best && sc.ratio > 0;
        const ver = t.version || 'unknown';

        h += `<div class="border border-gray-200 rounded-md p-4 ${isBest ? 'border-gray-900' : ''}">`;
        h += `<div class="flex items-center justify-between mb-1">`;
        h += `<a href="${esc(t.url)}" target="_blank" rel="noopener" class="text-sm font-medium underline hover:text-gray-900">${esc(t.name)}</a>`;
        if (isBest) h += '<span class="text-[10px] border border-gray-900 text-gray-900 px-1.5 py-0.5 rounded-full font-medium uppercase tracking-wider">Best</span>';
        h += '</div>';
        h += `<div class="text-[10px] text-gray-400 mb-2"><code>${esc(ver)}</code></div>`;
        h += `<div class="text-2xl font-bold text-gray-900">${sc.ratio.toFixed(1)}%</div>`;
        h += '<div class="text-[10px] text-gray-400 mt-0.5">avg. recovery rate</div>';

        // Avg duration + requests
        h += '<div class="flex gap-4 mt-2 text-[10px] text-gray-500">';
        h += `<span>avg. ${sc.duration.toFixed(1)}s</span>`;
        h += `<span>avg. ${sc.requests.toLocaleString()} reqs</span>`;
        h += '</div>';

        // Per-scenario bars
        h += '<div class="mt-3 space-y-1">';
        for (const s of data.scenarios) {
          const r = data.results[tid]?.[s];
          const ratio = r?.ratio || 0;
          const rc = ratio >= 90 ? 'high' : ratio >= 50 ? 'mid' : 'low';
          h += `<div class="flex items-center gap-2 text-[10px]"><span class="w-24 text-gray-400 truncate">${SCEN[s] || s}</span><div class="ratio-bar flex-1"><div class="ratio-fill ${rc}" style="width:${ratio}%"></div></div><span class="w-10 text-right text-gray-500">${ratio.toFixed(0)}%</span></div>`;
        }
        h += '</div></div>';
      }
      document.getElementById('score-cards')!.innerHTML = h;
    }
  </script>
</Layout>
