---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Figure from '../components/Figure.astro';
import Table from '../components/Table.astro';
import { strings } from '../i18n/strings';
import { benchmark, rankedTools } from '../lib/benchmark';
import { dispersionSvg } from '../lib/figures/dispersion';
import { heatmapSvg } from '../lib/figures/heatmap';
import { scatterSvg } from '../lib/figures/scatter';

const en = strings.en.benchmark;
const ranked = rankedTools();
const tools = ranked.map((r) => ({ id: r.id, meta: r.meta }));
const scenarios = benchmark.scenarios;
const features = benchmark.features;
const meta = benchmark.metadata;
const generatedDate = new Date(meta.generated_at).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});

// Feature-support: for each tool × feature, true if supported in ANY
// matching scenario, separately for index-enabled vs index-disabled.
type Mode = 'enabled' | 'disabled';
function featureSupport(mode: Mode): Record<string, Record<string, boolean>> {
  const matching = scenarios.filter((s) => s.includes(mode));
  const out: Record<string, Record<string, boolean>> = {};
  for (const t of tools) {
    out[t.id] = {};
    for (const f of features) {
      let sup = false;
      for (const sc of matching) {
        if (benchmark.results[t.id]?.[sc]?.features?.[f]?.supported) {
          sup = true;
          break;
        }
      }
      out[t.id][f] = sup;
    }
  }
  return out;
}
const supEnabled = featureSupport('enabled');
const supDisabled = featureSupport('disabled');

// Per-tool aggregate stats for Table 2.
const aggregates = ranked.map((r) => ({
  id: r.id,
  meta: r.meta,
  mean: r.mean,
  meanRequests: r.meanRequests,
  meanDuration: r.meanDuration,
}));
const bestRatio = Math.max(...aggregates.map((a) => a.mean));
const activeAgg = aggregates.filter((a) => a.mean > 0);
const bestRequests = activeAgg.length ? Math.min(...activeAgg.map((a) => a.meanRequests)) : 0;
const bestDuration = activeAgg.length ? Math.min(...activeAgg.map((a) => a.meanDuration)) : 0;

const fig2 = dispersionSvg(ranked);
const fig3 = heatmapSvg({
  scenarios,
  scenarioLabels: en.scen,
  tools,
  results: benchmark.results,
});
const fig4 = scatterSvg({
  scenarios,
  scenarioLabels: en.scen,
  tools,
  results: benchmark.results,
});

function toolUrl(t: { name: string; url: string }): string {
  return t.url || '#';
}

function ghPath(url: string): string {
  return url.replace('https://github.com/', '');
}
---

<Layout title="Benchmark — GitHacker" description="Side-by-side benchmark of .git folder exploitation tools.">
  <article class="max-w-[820px] mx-auto px-6 pt-10 pb-16">

    <header class="mb-6">
      <p class="smallcaps text-[12px] text-[var(--ink-mute)]" data-i18n="benchmark.preTitle">{en.preTitle}</p>
      <h1 class="mt-1 text-[28px] leading-[1.2]" data-i18n="benchmark.title" set:html={en.title} />
      <p class="mt-2 text-[14px] text-[var(--ink-soft)] leading-relaxed" data-i18n="benchmark.byline">{en.byline}</p>
      <p class="mt-3 text-[12px] text-[var(--ink-mute)]">
        <span class="smallcaps">Wang Yihang</span>
        &nbsp;·&nbsp; updated {generatedDate} &nbsp;·&nbsp; commit
        <code class="text-[11.5px]">{meta.git_commit}</code>
        &nbsp;·&nbsp; <span class="smallcaps">seed</span>&nbsp;{meta.test_repo_seed}
      </p>
    </header>

    <!-- ── §1 Setup ────────────────────────────────────────────── -->
    <SectionHeading n={1} id="setup">
      <span data-i18n="benchmark.s1Heading">{en.s1Heading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="benchmark.s1Body" set:html={en.s1Body} />

    <!-- ── §2 Feature Support — Table 1 ────────────────────────── -->
    <SectionHeading n={2} id="features">
      <span data-i18n="benchmark.s2Heading">{en.s2Heading}</span>
    </SectionHeading>

    {(['enabled', 'disabled'] as const).map((mode, mi) => {
      const sup = mode === 'enabled' ? supEnabled : supDisabled;
      const counts = tools.map((t) => features.filter((f) => sup[t.id][f]).length);
      const maxCount = Math.max(...counts);
      return (
        <Table
          n={mode === "enabled" ? "1a" : "1b"}
          label="Table"
          caption={`${en.t1Caption} ${mode === 'enabled' ? en.t1NoteEnabled : en.t1NoteDisabled}.`}
        >
          <table class="three-line-table">
            <thead>
              <tr>
                <th>{en.t1HeaderTool}</th>
                <th>{en.t1HeaderVersion}</th>
                {features.map((f) => <th>{en.feat[f] || f}</th>)}
                <th>{en.t1HeaderTotal}</th>
              </tr>
            </thead>
            <tbody>
              {tools.map((t, i) => {
                const count = counts[i];
                const isBest = count === maxCount;
                return (
                  <tr class:list={[isBest ? 'best' : '']}>
                    <td>
                      <a href={toolUrl(t.meta)} target="_blank" rel="noopener" class="underline">{t.meta.name}</a>
                    </td>
                    <td><code class="text-[11px]">{t.meta.version}</code></td>
                    {features.map((f) => (
                      <td>{sup[t.id][f] ? '✓' : <span class="text-[var(--ink-mute)] opacity-50">✗</span>}</td>
                    ))}
                    <td>{count}/{features.length}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </Table>
      );
    })}

    <!-- ── §3 Completeness — Table 2 + FIG. 2 ──────────────────── -->
    <SectionHeading n={3} id="completeness">
      <span data-i18n="benchmark.s3Heading">{en.s3Heading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="benchmark.s3Body">{en.s3Body}</p>

    <Table n={2} caption={en.t2Caption}>
      <table class="three-line-table">
        <thead>
          <tr>
            <th>{en.t2HeaderTool}</th>
            <th>{en.t2HeaderRatio}</th>
            <th>{en.t2HeaderDuration}</th>
            <th>{en.t2HeaderRequests}</th>
          </tr>
        </thead>
        <tbody>
          {aggregates.map((a) => {
            const bR = a.mean === bestRatio;
            const bD = a.mean > 0 && a.meanDuration === bestDuration;
            const bQ = a.mean > 0 && a.meanRequests === bestRequests;
            return (
              <tr>
                <td>
                  <a href={toolUrl(a.meta)} target="_blank" rel="noopener" class="underline">{a.meta.name}</a>
                </td>
                <td class:list={[bR ? 'best' : '']}>{a.mean.toFixed(1)}</td>
                <td class:list={[bD ? 'best' : '']}>{a.meanDuration.toFixed(1)}</td>
                <td class:list={[bQ ? 'best' : '']}>{Math.round(a.meanRequests)}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </Table>

    <Figure n={2} id="fig-dispersion" caption={en.fig2Caption}>
      <Fragment set:html={fig2} />
    </Figure>

    <!-- ── §4 Per-Scenario — Table 3 + FIG. 3 ──────────────────── -->
    <SectionHeading n={4} id="per-scenario">
      <span data-i18n="benchmark.s4Heading">{en.s4Heading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="benchmark.s4Body">{en.s4Body}</p>

    <Table n={3} caption={en.t3Caption}>
      <table class="three-line-table">
        <thead>
          <tr>
            <th>Tool</th>
            {scenarios.map((sc) => <th>{en.scen[sc] || sc}</th>)}
            <th>Mean</th>
          </tr>
        </thead>
        <tbody>
          {ranked.map((r) => (
            <tr class:list={[r.id === 'githacker' ? 'best' : '']}>
              <td>
                <a href={toolUrl(r.meta)} target="_blank" rel="noopener" class="underline">{r.meta.name}</a>
              </td>
              {scenarios.map((sc) => {
                const cell = benchmark.results[r.id]?.[sc];
                if (!cell) return <td class="text-[var(--ink-mute)]">—</td>;
                return <td>{cell.ratio.toFixed(1)}</td>;
              })}
              <td>{r.mean.toFixed(1)}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </Table>

    <Figure n={3} id="fig-heatmap" caption={en.fig3Caption}>
      <Fragment set:html={fig3} />
    </Figure>

    <!-- ── §5 Cost vs. Completeness — FIG. 4 ───────────────────── -->
    <SectionHeading n={5} id="cost">
      <span data-i18n="benchmark.s5Heading">{en.s5Heading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="benchmark.s5Body">{en.s5Body}</p>

    <Figure n={4} id="fig-scatter" caption={en.fig4Caption}>
      <Fragment set:html={fig4} />
    </Figure>

    <!-- ── §6 Discussion ───────────────────────────────────────── -->
    <SectionHeading n={6} id="discussion">
      <span data-i18n="benchmark.s6Heading">{en.s6Heading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="benchmark.s6Body">{en.s6Body}</p>

  </article>

  <script is:inline define:vars={{ I18N: strings.zh.benchmark }}>
    window.addEventListener('langchange', (e) => {
      const lang = e.detail;
      document.querySelectorAll('[data-i18n^="benchmark."]').forEach((el) => {
        const key = el.dataset.i18n.replace(/^benchmark\./, '');
        if (lang === 'en') {
          if (el.dataset.i18nOriginal) el.innerHTML = el.dataset.i18nOriginal;
          return;
        }
        if (!(key in I18N)) return;
        if (!el.dataset.i18nOriginal) el.dataset.i18nOriginal = el.innerHTML;
        el.innerHTML = I18N[key];
      });
    });
  </script>
</Layout>
