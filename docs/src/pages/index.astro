---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Figure from '../components/Figure.astro';
import Citation from '../components/Citation.astro';
import { strings } from '../i18n/strings';
import { benchmark, rankedTools } from '../lib/benchmark';
import { leaderboardSvg } from '../lib/figures/leaderboard';

const en = strings.en.home;
const ranked = rankedTools();
const figure1 = leaderboardSvg(ranked.map((r) => ({ id: r.id, meta: r.meta, mean: r.mean })));

const meta = benchmark.metadata;
const generatedDate = new Date(meta.generated_at).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});
---

<Layout title="GitHacker — An Empirical Study of .git Leakage Exploitation">
  <article class="max-w-[680px] mx-auto px-6 pt-10 pb-16">

    <!-- ── Title block ─────────────────────────────────────────── -->
    <header class="mb-7">
      <p class="smallcaps text-[12px] text-[var(--ink-mute)]" data-i18n="home.titleLine1" set:html={en.titleLine1} />
      <h1 class="mt-1 text-[30px] leading-[1.15]" data-i18n="home.titleLine2" set:html={en.titleLine2} />
      <p class="mt-3 text-[12.5px] text-[var(--ink-mute)]">
        <span class="smallcaps">Wang Yihang</span>
        &nbsp;·&nbsp; benchmark updated {generatedDate} &nbsp;·&nbsp; commit
        <code class="text-[11.5px]">{meta.git_commit}</code>
      </p>
    </header>

    <!-- ── Abstract ────────────────────────────────────────────── -->
    <section class="mb-7 pl-6 pr-2 border-l border-[var(--rule-soft)]">
      <p class="smallcaps text-[12px] text-[var(--ink-mute)]" data-i18n="home.abstractHeading">{en.abstractHeading}</p>
      <p class="mt-1 italic text-[14.5px] leading-[1.7]" data-i18n="home.abstract" set:html={en.abstract} />
    </section>

    <!-- ── §1 Introduction ─────────────────────────────────────── -->
    <SectionHeading n={1} id="intro">
      <span data-i18n="home.introHeading">{en.introHeading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="home.intro" set:html={en.intro} />

    <!-- ── §2 Summary of Findings ──────────────────────────────── -->
    <SectionHeading n={2} id="findings">
      <span data-i18n="home.findingsHeading">{en.findingsHeading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="home.findingsLead">{en.findingsLead}</p>
    <ol class="mt-3 ml-5 list-decimal text-[14.5px] leading-[1.7] space-y-2.5">
      <li data-i18n="home.finding1" set:html={en.finding1} />
      <li data-i18n="home.finding2" set:html={en.finding2} />
      <li data-i18n="home.finding3" set:html={en.finding3} />
    </ol>

    <Figure n={1} id="fig-leaderboard" caption={en.figure1Caption}>
      <Fragment set:html={figure1} />
    </Figure>

    <!-- ── §3 Reproduce ────────────────────────────────────────── -->
    <SectionHeading n={3} id="reproduce">
      <span data-i18n="home.reproduceHeading">{en.reproduceHeading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="home.reproduce">{en.reproduce}</p>
    <pre class="code-block mt-3 text-[12.5px]"><code>docker run wangyihang/githacker:benchmark python -m benchmark run</code></pre>
    <p class="mt-2 text-[13.5px]">
      <a href="/reproduce" class="underline" data-i18n="home.reproduceCta">{en.reproduceCta}</a>
    </p>

    <!-- ── §4 Related Work ─────────────────────────────────────── -->
    <SectionHeading n={4} id="related">
      <span data-i18n="home.relatedHeading">{en.relatedHeading}</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="home.relatedLead" set:html={en.relatedLead} />
    <ol class="mt-3 ml-5 list-decimal text-[13.5px] leading-relaxed space-y-1.5 text-[var(--ink-soft)]">
      <li>
        justinsteven.
        <em>Various abuses of <code>core.fsmonitor</code> in a directory's <code>.git/config</code></em>.
        2022. <a href="https://github.com/justinsteven/advisories" target="_blank" rel="noopener" class="underline">github.com/justinsteven/advisories</a>
      </li>
      <li>
        Driver Tom.
        <em>别想偷我源码：通用的针对源码泄露利用程序的反制</em>.
        2021. <a href="https://drivertom.blogspot.com/2021/08/git.html" target="_blank" rel="noopener" class="underline">drivertom.blogspot.com</a>
      </li>
      <li>
        Git project. <em>Security advisories</em>.
        <a href="https://github.com/git/git/security/advisories" target="_blank" rel="noopener" class="underline">github.com/git/git/security/advisories</a>
      </li>
    </ol>

    <!-- ── Citation ────────────────────────────────────────────── -->
    <h2 class="mt-9 mb-3 text-[20px]" data-i18n="home.citationHeading">{en.citationHeading}</h2>
    <Citation>{`@misc{githacker${new Date().getFullYear()},
  author       = {Wang, Yihang},
  title        = {GitHacker: An Empirical Study of .git Leakage Exploitation},
  year         = {${new Date().getFullYear()}},
  howpublished = {\\url{https://githacker.pages.dev}},
  note         = {Benchmark commit ${meta.git_commit}, seed ${meta.test_repo_seed}}
}`}</Citation>

  </article>

  <script is:inline define:vars={{ I18N: strings.zh.home, KEYS: Object.keys(strings.en.home) }}>
    // Swap text on language toggle.  Keys mirror strings.home.* paths.
    window.addEventListener('langchange', (e) => {
      const lang = e.detail;
      if (lang === 'en') {
        // We pre-rendered English, so on switching back, re-fetch the
        // original innerHTML from a stash on the element.
        document.querySelectorAll('[data-i18n^="home."]').forEach((el) => {
          if (el.dataset.i18nOriginal) el.innerHTML = el.dataset.i18nOriginal;
        });
        return;
      }
      document.querySelectorAll('[data-i18n^="home."]').forEach((el) => {
        const key = el.dataset.i18n.replace(/^home\./, '');
        if (!(key in I18N)) return;
        if (!el.dataset.i18nOriginal) el.dataset.i18nOriginal = el.innerHTML;
        el.innerHTML = I18N[key];
      });
    });
  </script>
</Layout>
