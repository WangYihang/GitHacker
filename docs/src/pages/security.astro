---
import Layout from '../layouts/Layout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Figure from '../components/Figure.astro';
import Table from '../components/Table.astro';
import Banner from '../components/Banner.astro';
import { security, orderedToolIds, passCount, passByCategory } from '../lib/security';
import { categoryBarsSvg } from '../lib/figures/categoryBars';
import { timelineSvg } from '../lib/figures/timeline';

const toolIds = orderedToolIds();
const tests = security.tests;
const disclosures = security.disclosures || [];
const embargoCount = security.embargo_count || 0;
const meta = {
  generated_at: security.generated_at,
  git_commit: security.git_commit,
};
const generatedDate = new Date(meta.generated_at).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric',
});

// Category order — categories that appear in the data, fixed display
// order so FIG. 5 stays comparable across runs.
const CAT_ORDER = ['RCE', 'AFW', 'Info', 'CVE'];
const presentCategories = CAT_ORDER.filter((c) => tests.some((t) => t.category === c));

const summaryRows = toolIds.map((id) => {
  const { pass, total } = passCount(id);
  return { id, meta: security.tools[id], pass, total };
});
const bestPass = Math.max(...summaryRows.map((r) => r.pass));

const fig5Rows = toolIds.map((id) => ({
  id,
  meta: security.tools[id],
  perCategory: passByCategory(id),
}));
const fig5 = categoryBarsSvg(fig5Rows, presentCategories);
const fig6 = timelineSvg(disclosures);

function fmtTestId(id: string): string {
  return id.toUpperCase().replace(/_/g, '-');
}

function severityClass(s: string): string {
  return ({ H: 'sev-h', M: 'sev-m', L: 'sev-l' } as Record<string, string>)[s] || '';
}

function verdictClass(v: string): string {
  return ({
    PASS:    'v-pass',
    FAIL:    'v-fail',
    TIMEOUT: 'v-timeout',
    ERROR:   'v-error',
  } as Record<string, string>)[v] || '';
}
---

<Layout title="Security — GitHacker" description="Adversarial benchmark of .git folder exploitation tools.">
  <article class="max-w-[820px] mx-auto px-6 pt-10 pb-16">

    <header class="mb-6">
      <p class="smallcaps text-[12px] text-[var(--ink-mute)]" data-i18n="security.preTitle">Adversarial Study</p>
      <h1 class="mt-1 text-[28px] leading-[1.2]" data-i18n="security.title">
        Adversarial Benchmark of <code>.git/</code> Pillagers
      </h1>
      <p class="mt-2 text-[14px] text-[var(--ink-soft)] leading-relaxed" data-i18n="security.byline">
        Companion to <a href="/benchmark" class="underline">Benchmark</a>.
        Measures how each pillager holds up when the served
        <code>.git/</code> is malicious.
      </p>
      <p class="mt-3 text-[12px] text-[var(--ink-mute)]">
        <span class="smallcaps">Wang Yihang</span>
        &nbsp;·&nbsp; updated {generatedDate} &nbsp;·&nbsp; commit
        <code class="text-[11.5px]">{meta.git_commit.slice(0, 7)}</code>
      </p>
    </header>

    {embargoCount > 0 && (
      <Banner kind="embargo" title="Coordinated disclosure.">
        <span data-i18n="security.embargo">
          {embargoCount} finding{embargoCount === 1 ? ' has' : 's have'} not yet been reported upstream.
          The verdicts below are public — the test corpus itself is published research, so a
          FAIL leaks no new vulnerability detail.  The affected tool names render as
          <em>Tool&nbsp;A…F</em> until each maintainer has been contacted; the internal mapping
          is held until coordinated disclosure completes.
        </span>
      </Banner>
    )}

    <!-- ── §1 Threat Model ─────────────────────────────────────── -->
    <SectionHeading n={1} id="threat-model">
      <span data-i18n="security.s1Heading">Threat Model</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s1Body">
      We run each pillager against a series of maliciously-crafted
      <code>.git/</code> directories, modeled after published research
      (justinsteven 2022, Driver&nbsp;Tom 2021) and well-known Git CVEs.
      A test is a <strong>FAIL</strong> if the malicious server attains
      code execution, arbitrary file write, or SSRF against the tool's
      container during recovery; <strong>PASS</strong> if the tool
      refused or contained the payload.  Tools with unreported findings
      are anonymized as <em>Tool&nbsp;A…F</em>; the mapping is maintained
      internally until coordinated disclosure completes (see §5).
    </p>

    <!-- ── §2 Test Corpus ──────────────────────────────────────── -->
    <SectionHeading n={2} id="corpus">
      <span data-i18n="security.s2Heading">Test Corpus</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s2Body">
      {tests.length} tests, drawn from public advisories and the Git CVE feed.
      Categories: RCE (remote code execution against the tool host),
      AFW (arbitrary file write outside the output directory), Info
      (information disclosure, e.g. SSRF), CVE (regression tests for
      Git CVEs that fire on <code>git clone</code> / <code>checkout</code>).
    </p>

    <Table n={4} caption="Adversarial test corpus.  CVE column lists upstream identifiers where available.">
      <table class="three-line-table">
        <thead>
          <tr>
            <th>Test</th>
            <th>Category</th>
            <th>Sev.</th>
            <th>CVE</th>
            <th>Description</th>
          </tr>
        </thead>
        <tbody>
          {tests.map((t) => (
            <tr>
              <td><code class="text-[11px]">{fmtTestId(t.id)}</code></td>
              <td>{t.category}</td>
              <td><span class={severityClass(t.severity)}>{t.severity}</span></td>
              <td>
                {t.cve ? (
                  <a href={`https://nvd.nist.gov/vuln/detail/${t.cve}`} target="_blank" rel="noopener" class="underline text-[11.5px]">{t.cve}</a>
                ) : (
                  <span class="opacity-50">—</span>
                )}
              </td>
              <td class="text-[12.5px] !text-left">{t.description}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </Table>

    <!-- ── §3 Results Summary ──────────────────────────────────── -->
    <SectionHeading n={3} id="summary">
      <span data-i18n="security.s3Heading">Results Summary</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s3Body">
      PASS rate per tool over the {tests.length}-test corpus.  Higher is
      better — a PASS means the tool refused or contained the payload.
      Best in bold.
    </p>

    <Table n={5} caption="Per-tool PASS rate across the full adversarial corpus.  Best in bold.">
      <table class="three-line-table">
        <thead>
          <tr>
            <th>Tool</th>
            <th>Version</th>
            <th>PASS / Total</th>
            <th>Rate</th>
          </tr>
        </thead>
        <tbody>
          {summaryRows.map((r) => {
            const isBest = r.pass === bestPass;
            const pct = r.total > 0 ? ((r.pass / r.total) * 100).toFixed(1) : '0.0';
            return (
              <tr class:list={[isBest ? 'best' : '']}>
                <td>
                  {r.meta.url ? (
                    <a href={r.meta.url} target="_blank" rel="noopener" class="underline">{r.meta.name}</a>
                  ) : (
                    <em>{r.meta.name}</em>
                  )}
                </td>
                <td><code class="text-[11px]">{r.meta.version}</code></td>
                <td>{r.pass} / {r.total}</td>
                <td>{pct}%</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </Table>

    <Figure n={5} id="fig-category" caption="PASS counts per tool, segmented by attack category.  Darker segments encode higher-severity categories (RCE darkest, Info lightest) so the figure retains comparison under grayscale print.">
      <Fragment set:html={fig5} />
    </Figure>

    <!-- ── §4 Per-Test Matrix ──────────────────────────────────── -->
    <SectionHeading n={4} id="matrix">
      <span data-i18n="security.s4Heading">Per-Test Matrix</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s4Body">
      PASS / FAIL grid per (test × tool).  Every verdict is published;
      anonymity is enforced only at the tool name (<em>Tool&nbsp;A…F</em>),
      since the test corpus is already public research.
    </p>

    <Table n={6} caption="Per-test verdict matrix.  PASS = tool resisted the payload; FAIL = exploit succeeded.">
      <table class="three-line-table">
        <thead>
          <tr>
            <th>Test</th>
            <th>Cat.</th>
            <th>Sev.</th>
            {toolIds.map((id) => <th>{security.tools[id].name}</th>)}
          </tr>
        </thead>
        <tbody>
          {tests.map((t) => (
            <tr>
              <td><code class="text-[11px]">{fmtTestId(t.id)}</code></td>
              <td class="text-[12px]">{t.category}</td>
              <td><span class={severityClass(t.severity)}>{t.severity}</span></td>
              {toolIds.map((id) => {
                const r = t.results[id];
                if (!r) return <td class="opacity-50">—</td>;
                return <td><span class={verdictClass(r.verdict)}>{r.verdict}</span></td>;
              })}
            </tr>
          ))}
        </tbody>
      </table>
      <Fragment slot="footnotes">
        "—" means the tool did not produce a verdict for that test (run error or skip), not that the result is withheld.
      </Fragment>
    </Table>

    <!-- ── §5 Disclosure Timeline ──────────────────────────────── -->
    <SectionHeading n={5} id="timeline">
      <span data-i18n="security.s5Heading">Disclosure Timeline</span>
    </SectionHeading>
    <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s5Body">
      Each finding's coordinated-disclosure state, plotted across
      observation, vendor contact, and patch landing.  Findings still
      under embargo do not appear here until we contact upstream.
    </p>

    <Figure n={6} id="fig-timeline" caption="Disclosure timeline.  Bar spans from first observation to most recent milestone.  Markers: ● observed · ▪ reported · ◆ patched.">
      <Fragment set:html={fig6} />
    </Figure>

    {disclosures.length > 0 && (
      <Table n={7} caption="Disclosure tracker.  Status terms follow standard coordinated-disclosure stages.">
        <table class="three-line-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Test</th>
              <th>Tool</th>
              <th>Sev.</th>
              <th>Status</th>
              <th>First obs.</th>
              <th>CVE</th>
            </tr>
          </thead>
          <tbody>
            {disclosures.map((d) => (
              <tr>
                <td><code class="text-[11px]">{d.id}</code></td>
                <td><code class="text-[11px]">{fmtTestId(d.test)}</code></td>
                <td>{d.tool}</td>
                <td><span class={severityClass(d.severity)}>{d.severity}</span></td>
                <td class="text-[12px]"><code>{d.status}</code></td>
                <td class="text-[12px]">{d.first_observed || '—'}</td>
                <td>
                  {d.cve ? (
                    <a href={`https://nvd.nist.gov/vuln/detail/${d.cve}`} target="_blank" rel="noopener" class="underline text-[11.5px]">{d.cve}</a>
                  ) : (
                    <span class="opacity-50">—</span>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </Table>
    )}

    <!-- ── §6 Anonymity Policy ─────────────────────────────────── -->
    {embargoCount > 0 && (
      <>
        <SectionHeading n={6} id="anonymity">
          <span data-i18n="security.s6Heading">Anonymity Policy</span>
        </SectionHeading>
        <p class="text-[14.5px] leading-[1.7]" data-i18n="security.s6Body">
          {embargoCount} finding{embargoCount === 1 ? ' is' : 's are'} currently pre-disclosure.  We publish the
          full verdict matrix and the disclosure tracker, but the affected tool names render as
          <em>Tool&nbsp;A…F</em> until each upstream maintainer is contacted.  The mapping is held in this
          repository's private disclosure tracker and is rotated forward — never reused — once a finding
          reaches <code>disclosed</code>.  GitHacker is never anonymized in either direction.
        </p>
      </>
    )}

    <!-- ── References ──────────────────────────────────────────── -->
    <h2 class="mt-9 mb-3 text-[20px]">References</h2>
    <ol class="ml-5 list-decimal text-[13.5px] leading-relaxed space-y-1.5 text-[var(--ink-soft)]">
      <li>
        justinsteven.
        <em>Various abuses of <code>core.fsmonitor</code> in a directory's <code>.git/config</code></em>.
        2022. <a href="https://github.com/justinsteven/advisories" target="_blank" rel="noopener" class="underline">github.com/justinsteven/advisories</a>
      </li>
      <li>
        Driver Tom.
        <em>别想偷我源码：通用的针对源码泄露利用程序的反制</em>.
        2021. <a href="https://drivertom.blogspot.com/2021/08/git.html" target="_blank" rel="noopener" class="underline">drivertom.blogspot.com</a>
      </li>
      <li>
        Git project.  <em>Security advisories</em>.
        <a href="https://github.com/git/git/security/advisories" target="_blank" rel="noopener" class="underline">github.com/git/git/security/advisories</a>
      </li>
    </ol>

  </article>

  <style is:global>
    .v-pass    { color: var(--c-pass); }
    .v-fail    { color: var(--c-fail); font-weight: 700; }
    .v-timeout { color: var(--c-timeout); }
    .v-error   { color: var(--c-error); }
    .sev-h     { color: var(--sev-h); font-weight: 600; }
    .sev-m     { color: var(--sev-m); }
    .sev-l     { color: var(--sev-l); }
  </style>

  <script is:inline>
    const SEC_ZH = {
      preTitle: '对抗性研究',
      title: '<code>.git/</code> 利用工具的对抗性基准测试',
      byline: '与 <a href="/benchmark" class="underline">Benchmark</a> 互为镜像。衡量 pillager 工具面对恶意 <code>.git/</code> 时的加固程度。',
      embargo: '当前仍有发现尚未上报上游。下方判定矩阵照常公开 —— 测试集本身已是公开研究，FAIL 并不会泄露新的漏洞细节。仅工具名按 <em>Tool A…F</em> 匿名化，直至我们联系完上游维护者；内部映射在协调披露完成前保留。',
      s1Heading: '威胁模型',
      s1Body: '我们让每个 pillager 工具针对一系列恶意 <code>.git/</code> 仓库进行恢复，攻击场景源自已发表研究（justinsteven 2022、Driver Tom 2021）及已公开的 Git CVE。若恶意服务器在恢复期间对工具容器达成代码执行、任意文件写入或 SSRF，则该测试记为 <strong>FAIL</strong>；若工具拒绝或限制 payload 则为 <strong>PASS</strong>。未披露的工具以 <em>Tool A…F</em> 匿名化；映射在协调披露完成前保留内部（见 §5）。',
      s2Heading: '测试集',
      s2Body: '测试用例取自公开通告及 Git 官方 CVE 列表。类别：RCE（对工具主机的远程代码执行）、AFW（写出输出目录外的任意文件）、Info（信息泄露，如 SSRF）、CVE（针对 git clone / checkout 触发的 Git CVE 回归测试）。',
      s3Heading: '总体结果',
      s3Body: '每个工具在全部测试上的 PASS 通过率。越高越好 —— PASS 表示工具拒绝或限制了 payload。最优值加粗。',
      s4Heading: '逐项矩阵',
      s4Body: '按（测试 × 工具）的 PASS / FAIL 网格。所有判定都公开 —— 匿名化只作用在工具名（<em>Tool A…F</em>），因为测试集本身已是公开研究。',
      s5Heading: '披露时间线',
      s5Body: '每条发现的协调披露状态 —— 从首次观察、上报上游到补丁落地。仍处于联系前阶段的发现也照常显示，只是工具名匿名。',
      s6Heading: '匿名化政策',
      s6Body: '当前有若干发现仍处于披露前阶段。我们照常公开完整的判定矩阵与披露跟踪表，仅在被影响工具的名字上以 <em>Tool A…F</em> 匿名，直到我们联系完上游维护者。内部映射保存在本仓库的私有跟踪表中，且只会在每次状态推进到 <code>disclosed</code> 之后单向消除，绝不复用。GitHacker 自身在任何方向上均不匿名。',
    };
    window.addEventListener('langchange', (e) => {
      const lang = e.detail;
      document.querySelectorAll('[data-i18n^="security."]').forEach((el) => {
        const key = el.dataset.i18n.replace(/^security\./, '');
        if (lang === 'en') {
          if (el.dataset.i18nOriginal) el.innerHTML = el.dataset.i18nOriginal;
          return;
        }
        if (!(key in SEC_ZH)) return;
        if (!el.dataset.i18nOriginal) el.dataset.i18nOriginal = el.innerHTML;
        el.innerHTML = SEC_ZH[key];
      });
    });
  </script>
</Layout>
